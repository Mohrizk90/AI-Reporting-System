OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BREVO_API_KEY=

# Google Custom Search JSON API (optional; for web search features — not used by report pipeline unless wired)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Google Search Console API (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Client type in Google Cloud: "installed" = Desktop app (default). "web" = Web application.
# If you created a Web client, set web and add this exact redirect under Authorized redirect URIs:
#   http://127.0.0.1:8765/
GOOGLE_OAUTH_CLIENT_TYPE=installed
# GOOGLE_OAUTH_REDIRECT_PORT=8765
# Set to 1 only with a Desktop OAuth client (random port; Web clients will get redirect_uri_mismatch).
# GOOGLE_OAUTH_USE_DYNAMIC_PORT=0
# Optional: path to saved OAuth token (default: ./google_gsc_token.json)
# GOOGLE_GSC_TOKEN_PATH=
# Property URL for scripts/read_gsc_data.py — must match Search Console exactly
# GOOGLE_SEARCH_CONSOLE_SITE=https://www.example.com/
